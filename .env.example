# Backend IRIS en Vercel -> Ollama publico via Cloudflare Tunnel.
OLLAMA_BASE_URL=https://ollama.irisapp.es
OLLAMA_MODEL=llama3.1:latest

# Por defecto el chat queda publico para que web y Android puedan usarlo.
# Activalo solo si todos los clientes envian Authorization: Bearer <IRIS_API_KEY>.
IRIS_REQUIRE_API_KEY=false
IRIS_API_KEY=
